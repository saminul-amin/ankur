{
  "name": "ankur",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "build": "next build",
    "spike:gemma": "node --env-file-if-exists=.env.local --import tsx scripts/provider-spike/run.ts",
    "verify:vertical-slice": "node --env-file-if-exists=.env.local --import tsx scripts/vertical-slice/run-live.ts",
    "verify:ingestion": "node --env-file-if-exists=.env.local --import tsx scripts/ingestion/run-live.ts",
    "verify:mixed-assessment": "node --env-file-if-exists=.env.local --import tsx scripts/mixed-assessment/run-live.ts",
    "benchmark:provider": "node --env-file-if-exists=.env.local --import tsx scripts/provider-reliability/run.ts",
    "verify:production-live": "node --import tsx scripts/production/run-live.ts"
  },
  "dependencies": {
    "@google/genai": "latest",
    "lucide-react": "^1.25.0",
    "motion": "^12.42.2",
    "next": "16.2.11",
    "pdfjs-dist": "6.1.200",
    "react": "19.2.8",
    "react-dom": "19.2.8",
    "server-only": "0.0.1",
    "zod": "latest"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@eslint/js": "latest",
    "@playwright/test": "1.61.1",
    "@tailwindcss/postcss": "^4.3.3",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "latest",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "eslint": "latest",
    "jsdom": "29.1.1",
    "pdf-lib": "1.17.1",
    "tailwindcss": "^4.3.3",
    "tsx": "4.23.1",
    "typescript": "latest",
    "typescript-eslint": "latest",
    "vitest": "latest"
  },
  "overrides": {
    "next": {
      "postcss": "8.5.10",
      "sharp": "0.35.0"
    }
  }
}
