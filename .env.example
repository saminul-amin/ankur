# Server-only secret. Never expose through NEXT_PUBLIC_* or commit a real value.
GEMINI_API_KEY=

# The live spike refuses to run unless this is explicitly set to true.
ANKUR_PROVIDER_SPIKE_OPT_IN=false

# Live application generation is disabled by default; sample mode remains available.
ANKUR_LIVE_AI_ENABLED=false
ANKUR_SAMPLE_MODE_ENABLED=true

# Optional, quota-consuming comparison. The primary 26B spike always runs first.
ANKUR_SPIKE_COMPARE_31B=false

GEMMA_PRIMARY_MODEL=gemma-4-26b-a4b-it
# 31B is spike-only and is never an automatic application fallback.
GEMMA_ESCALATION_MODEL=gemma-4-31b-it
GEMMA_NATIVE_STRUCTURED_OUTPUT=native
AI_REQUEST_TIMEOUT_MS=90000
